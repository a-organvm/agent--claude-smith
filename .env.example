# Claude Agent Orchestrator - Environment Variables
# Copy this file to .env and fill in the values

# ============================================================================
# Required: Claude API Key
# ============================================================================
# Can be provided directly or resolved from 1Password
ANTHROPIC_API_KEY=

# ============================================================================
# 1Password Integration (recommended)
# ============================================================================
# Service account token for 1Password SDK
# Create at: https://my.1password.com/developer-tools/infrastructure-secrets/service-accounts
OP_SERVICE_ACCOUNT_TOKEN=

# ============================================================================
# Optional: chezmoi Templates
# ============================================================================
# Path to directory containing agent config templates (.toml.tmpl files)
CLAUDE_AGENT_TEMPLATES=./templates/agent-configs

# ============================================================================
# Optional: External AI Services
# ============================================================================
# Only needed if using the ai-bridge agent
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# ============================================================================
# Optional: Security Scanning
# ============================================================================
# Only needed if using security-auditor with Snyk integration
SNYK_TOKEN=

# ============================================================================
# Optional: Session Configuration
# ============================================================================
# Directory for session persistence (default: ./.sessions)
# CLAUDE_AGENT_SESSIONS=./.sessions

# Maximum concurrent agents (default: 5)
# CLAUDE_AGENT_MAX_CONCURRENT=5

# Default model (default: claude-sonnet-4-20250514)
# CLAUDE_AGENT_MODEL=claude-sonnet-4-20250514
